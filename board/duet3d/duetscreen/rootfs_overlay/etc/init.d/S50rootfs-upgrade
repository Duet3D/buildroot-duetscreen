#!/bin/sh

UPGRADE_FILE="update.tar.gz"
PIDFILE="/var/run/S50rootfs-upgrade.pid"
UPGRADE_STATUS_SOCKET="/run/duetscreen/upgrade.sock"
UPGRADE_STATUS_DIR="/var/lib/duetscreen"
UPGRADE_STATUS_FILE="$UPGRADE_STATUS_DIR/upgrade_status.json"
UPGRADE_STATUS_SEQ_FILE="$UPGRADE_STATUS_DIR/upgrade_status.sequence"

UPDATE_BUILDROOT_VERSION=""
PATCH_WARNING=0


flush_upgrade_writes() {
	echo "Flushing filesystem buffers to persistent storage..."

	# Flush all dirty buffers first.
	sync

	# Best-effort block-level flush for the rootfs backing device.
	if command -v blockdev >/dev/null 2>&1; then
		ROOT_DEV=$(awk '$2 == "/" { print $1; exit }' /proc/mounts)
		if [ -n "$ROOT_DEV" ] && [ -b "$ROOT_DEV" ]; then
			blockdev --flushbufs "$ROOT_DEV" >/dev/null 2>&1 || true
		fi
	fi

	# Flush once more after metadata updates.
	sync
}


# Version check function (robust BusyBox tar extraction)
check_version() {
	ROOTFS_VERSION_FILE="/etc/buildroot_version"
	UPDATE_VERSION_FILE="/tmp/update_buildroot_version"
	UPDATE_TAR="$1"
	UPDATE_BUILDROOT_VERSION=""
	PATCH_WARNING=0

	# Try to extract buildroot_version (with or without ./ prefix)
	gunzip -c "$UPDATE_TAR" | tar -xOf - buildroot_version 2>/dev/null > "$UPDATE_VERSION_FILE"
	if [ ! -s "$UPDATE_VERSION_FILE" ]; then
		gunzip -c "$UPDATE_TAR" | tar -xOf - ./buildroot_version 2>/dev/null > "$UPDATE_VERSION_FILE"
	fi
	if [ ! -s "$UPDATE_VERSION_FILE" ]; then
		echo "Failed to extract buildroot_version from update package '$UPDATE_TAR', skipping version check."
		rm -f "$UPDATE_VERSION_FILE"
		return 0
	fi

	if [ ! -f "$ROOTFS_VERSION_FILE" ]; then
		echo "Buildroot version file missing, skipping check."
		return 0
	fi

	ROOTFS_VERSION=$(cat "$ROOTFS_VERSION_FILE" | tr -d '\r\n')
	UPDATE_VERSION=$(cat "$UPDATE_VERSION_FILE" | tr -d '\r\n')
	UPDATE_BUILDROOT_VERSION="$UPDATE_VERSION"

	echo "Current rootfs version: $ROOTFS_VERSION, update version: $UPDATE_VERSION"

	# Compare major.minor, ignore patch if not present
	ROOTFS_BASE=$(echo "$ROOTFS_VERSION" | cut -d. -f1,2)
	UPDATE_BASE=$(echo "$UPDATE_VERSION" | cut -d. -f1,2)

	if [ "$ROOTFS_BASE" != "$UPDATE_BASE" ]; then
		echo "Version mismatch: rootfs $ROOTFS_VERSION, update $UPDATE_VERSION"
		return 1
	fi

	# Always check patch version, but do not block upgrade
	ROOTFS_PATCH=$(echo "$ROOTFS_VERSION" | cut -d. -f3)
	UPDATE_PATCH=$(echo "$UPDATE_VERSION" | cut -d. -f3)
	if [ -n "$ROOTFS_PATCH" ] && [ -n "$UPDATE_PATCH" ] && [ "$ROOTFS_PATCH" != "$UPDATE_PATCH" ]; then
		echo "Patch version differs: rootfs $ROOTFS_VERSION, update $UPDATE_VERSION"
		PATCH_WARNING=1
	else
		PATCH_WARNING=0
	fi
	return 0
}

post_upgrade_status() {
	RESULT="$1"
	TARGET_BUILDROOT="$2"

	echo "Posting upgrade status: result=$RESULT, target_buildroot=$TARGET_BUILDROOT"

	mkdir -p "$UPGRADE_STATUS_DIR" >/dev/null 2>&1 || true

	if [ -f "$UPGRADE_STATUS_SEQ_FILE" ]; then
		SEQUENCE=$(cat "$UPGRADE_STATUS_SEQ_FILE" 2>/dev/null || printf '0')
	else
		SEQUENCE="0"
	fi

	case "$SEQUENCE" in
		''|*[!0-9]*)
			SEQUENCE="0"
			;;
	esac

	SEQUENCE=$((SEQUENCE + 1))
	printf '%s\n' "$SEQUENCE" > "$UPGRADE_STATUS_SEQ_FILE"

	PAYLOAD=$(printf '{"result":"%s","target_buildroot":"%s","sequence":%s}' "$RESULT" "$TARGET_BUILDROOT" "$SEQUENCE")
	TMP_STATUS_FILE="${UPGRADE_STATUS_FILE}.tmp.$$"
	printf '%s\n' "$PAYLOAD" > "$TMP_STATUS_FILE"
	mv "$TMP_STATUS_FILE" "$UPGRADE_STATUS_FILE"
	echo "Upgrade status file updated: $UPGRADE_STATUS_FILE"

	send_upgrade_status_socket() {
		if command -v socat >/dev/null 2>&1; then
			printf '%s' "$PAYLOAD" | socat -u - "UNIX-SENDTO:$UPGRADE_STATUS_SOCKET" >/dev/null 2>&1 && return 0
		elif command -v nc >/dev/null 2>&1; then
			printf '%s' "$PAYLOAD" | nc -u -U "$UPGRADE_STATUS_SOCKET" >/dev/null 2>&1 && return 0
			printf '%s' "$PAYLOAD" | nc -U "$UPGRADE_STATUS_SOCKET" >/dev/null 2>&1 && return 0
		fi
		return 1
	}

	has_socket_sender() {
		command -v socat >/dev/null 2>&1 && return 0
		command -v nc >/dev/null 2>&1 && return 0
		return 1
	}

	if ! has_socket_sender; then
		echo "No socket sender available (socat/nc missing); relying on persisted status file."
		return 0
	fi

	ATTEMPT=0
	while [ "$ATTEMPT" -lt 25 ]; do
		if [ -S "$UPGRADE_STATUS_SOCKET" ] && send_upgrade_status_socket; then
			echo "Posted upgrade status to socket."
			return 0
		fi
		ATTEMPT=$((ATTEMPT + 1))
		sleep 0.2
	done

	echo "Upgrade status socket notification failed after retries (will be consumed from status file on startup)."
}
do_upgrade() {
	FILE="$1"
	UPGRADE_OK=0

	# Run pre-update if applicable
	gunzip -c "$FILE" | tar -xvC / pre-update >/dev/null 2>&1 || true
	if [ -f /pre-update ]; then
		chmod +x /pre-update
		echo "Running pre-update script..."
		/pre-update "$FILE"
	fi

	# Extract everything over rootfs and delete pre-update if needed
	if gunzip "$FILE" -c | tar -xvC / > /dev/null; then
		rm -f "$FILE"
		UPGRADE_OK=1
	fi
	rm -f /pre-update

	# Run post-update if applicable
	if [ -f /post-update ]; then
		chmod +x /post-update
		echo "Running post-update script..."
		/post-update
		rm /post-update
	fi

	if [ "$UPGRADE_OK" -eq 1 ]; then
		flush_upgrade_writes
		return 0
	fi
	return 1
}

start() {
	# Check for update file in /boot and install it if present
	if [ -f "/boot/$UPGRADE_FILE" ]; then
		echo "Found $UPGRADE_FILE on /boot, installing... "
		if check_version "/boot/$UPGRADE_FILE"; then
			if do_upgrade "/boot/$UPGRADE_FILE"; then
				if [ "$PATCH_WARNING" -eq 1 ]; then
					post_upgrade_status "warning" "$UPDATE_BUILDROOT_VERSION"
				else
					post_upgrade_status "success" "$UPDATE_BUILDROOT_VERSION"
				fi
				flush_upgrade_writes
				echo "OK"
			else
				echo "ERROR"
			fi
		else
			echo "Version check failed, upgrade aborted."
			post_upgrade_status "error" "$UPDATE_BUILDROOT_VERSION"
			rm "/boot/$UPGRADE_FILE"
		fi
	fi

	# Keep checking for updates on USB drives
	while true; do
		for MOUNT_POINT in $(echo /media/usb[0-7] 2>/dev/null); do
			if mountpoint -q "$MOUNT_POINT"; then
				if [ -f "$MOUNT_POINT/$UPGRADE_FILE" ]; then
					echo "Found $UPGRADE_FILE on $MOUNT_POINT, installing... "
					if check_version "$MOUNT_POINT/$UPGRADE_FILE"; then
						if do_upgrade "$MOUNT_POINT/$UPGRADE_FILE"; then
							if [ "$PATCH_WARNING" -eq 1 ]; then
								post_upgrade_status "warning" "$UPDATE_BUILDROOT_VERSION"
							else
								post_upgrade_status "success" "$UPDATE_BUILDROOT_VERSION"
							fi
							flush_upgrade_writes
							echo "OK"
						else
							echo "ERROR"
						fi
					else
						echo "Version check failed, upgrade aborted."
						post_upgrade_status "error" "$UPDATE_BUILDROOT_VERSION"
						mv "$MOUNT_POINT/$UPGRADE_FILE" "$MOUNT_POINT/${UPGRADE_FILE}.invalid.$(date +%Y%m%d%H%M%S)"
					fi
				fi
			fi
		done
		sleep 2
	done &
	echo $! > "$PIDFILE"
}

stop() {
	if [ -f "$PIDFILE" ]; then
		kill $(cat "$PIDFILE")
		rm -f "$PIDFILE"
	fi
}

restart() {
	stop
	start
}

case "$1" in
	start)
		start
		;;
	stop)
		stop
		;;
	restart)
		restart
		;;
	*)
		echo "Usage: $0 {start|stop|restart}" >&2
		exit 1
		;;
esac

