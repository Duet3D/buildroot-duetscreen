config BR2_PACKAGE_DUETSCREEN
	bool "duetscreen"
	depends on BR2_INSTALL_LIBSTDCPP
	depends on !BR2_STATIC_LIBS
	depends on BR2_TOOLCHAIN_HAS_THREADS
	depends on BR2_USE_WCHAR
	depends on BR2_TOOLCHAIN_GCC_AT_LEAST_8 # C++20
	select BR2_HOST_CMAKE_AT_LEAST_3_30
	select BR2_PACKAGE_SDL2
	select BR2_PACKAGE_SPDLOG
	select BR2_PACKAGE_FMT
	select BR2_PACKAGE_SOCAT
	select BR2_PACKAGE_LIBUSB_COMPAT
	select BR2_PACKAGE_MUSL_FTS if !BR2_TOOLCHAIN_USES_GLIBC
	select BR2_PACKAGE_WPA_SUPPLICANT_WPA_CLIENT_SO
	select BR2_PACKAGE_FREETYPE
	select BR2_PACKAGE_LIBXKBCOMMON
	select BR2_PACKAGE_XKEYBOARD_CONFIG
	help
	  Display application for Duet3D DuetScreen devices

	  DuetScreen is an application using LVGL to display various
	  information about Duet3D controllers using RepRapFirmware.

	  https://www.duet3d.com

